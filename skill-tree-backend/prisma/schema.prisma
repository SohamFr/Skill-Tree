generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Developer {
  id            String   @id @default(uuid())
  githubUsername String   @unique
  name          String?
  avatarUrl     String?
  bio           String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  repositories Repository[]
  deployments  Deployment[]
  skills       Skill[]
  credentials  Credential[]
}

model Repository {
  id               String   @id @default(uuid())
  developerId      String
  repoName         String
  repoUrl          String
  stars            Int      @default(0)
  forks            Int      @default(0)
  language         String?
  topics           String[]
  complexity       Float?
  contributionScore Float?
  analyzedAt       DateTime @default(now())

  developer Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)
}

model Deployment {
  id              String   @id @default(uuid())
  developerId     String
  url             String
  status          String?
  responseTime    Float?
  isHttps         Boolean?
  isAccessible    Boolean?
  lighthouseScore Float?
  verifiedAt      DateTime @default(now())

  developer Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)
}

model Skill {
  id         String   @id @default(uuid())
  developerId String
  name       String
  level      String?
  verified   Boolean  @default(false)
  evidence   String?

  developer Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)
}

model Credential {
  id         String   @id @default(uuid())
  developerId String
  title      String
  issuer     String?
  verifiedAt DateTime?
  proofUrl   String?

  developer Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)
}
